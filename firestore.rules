rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper simplifié pour éviter les erreurs de lecture circulaire
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS : Lecture pour soi ou admin
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if false; // Géré par Cloud Functions
    }

    // RESERVATIONS : Important pour le calendrier et le portail guest
    match /reservations/{bookingId} {
      allow read: if true; // Permettre la lecture pour vérifier les dates
      allow write: if false;
    }

    // CALENDRIER : Correction pour l'erreur de ton log
    match /calendars/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /availability/{date} {
      allow read: if true;
      allow write: if false;
    }

    // CONFIG : On permet la lecture de 'wifi' car le JS Guest en a besoin
    match /config/{doc} {
      // On autorise la lecture publique des infos non-sensibles
      // Pour le wifi, ton code JS filtre déjà l'affichage par heure, 
      // mais Firestore doit autoriser la lecture du document.
      allow read: if doc != 'secrets' && doc != 'owner';
      allow write: if isAdmin();
    }

    // GUESTS & PUSH : Réservé à l'admin
    match /guests/{email} { allow read, write: if isAdmin(); }
    match /push_history/{id} { allow read: if isAdmin(); }
    match /subscriptions/{id} { allow read, write: if true; } // Pour les abonnés push

    // Par défaut : Refusé
    match /{document=**} {
      allow read, write: if false;
    }
  }
}