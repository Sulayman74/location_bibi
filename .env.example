# ================================================
# La Cabine du Cap d'Agde – Variables d'environnement
# ================================================
# Copier ce fichier en .env.local pour le développement
# Les secrets de production sont dans Firebase Secret Manager

# Firebase (frontend - safe to expose)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_PROJECT_ID=votre-projet
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FCM_VAPID_KEY=BNs8...

# Stripe (frontend - publishable key only)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ==================== SECRETS (Firebase Secret Manager) ====================
